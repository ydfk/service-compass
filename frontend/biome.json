{
  "$schema": "https://biomejs.dev/schemas/2.0.6/schema.json",
  "files": { "includes": ["src/**", "*.ts", "*.json"] },
  "formatter": {
    "enabled": true,
    "indentStyle": "space",
    "indentWidth": 2,
    "lineWidth": 100
  },
  "javascript": {
    "formatter": {
      "quoteStyle": "single",
      "semicolons": "asNeeded",
      "trailingCommas": "all"
    }
  },
  "linter": { "enabled": true, "rules": { "recommended": true } },
  "overrides": [
    {
      "includes": ["src/**/*.vue"],
      "linter": {
        "rules": {
          "correctness": { "noUnusedImports": "off", "noUnusedVariables": "off" }
        }
      }
    }
  ]
}
